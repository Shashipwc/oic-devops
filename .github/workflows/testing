name: OIC Migration UAT тЖТ SIT (OAuth Final)

on:
  workflow_dispatch:

jobs:
  migrate:
    runs-on: ubuntu-latest

    steps:
      # тЬЕ Install jq
      - name: Install jq
        run: sudo apt-get update && sudo apt-get install -y jq

      # тЬЕ Set Variables
      - name: Set Variables
        run: |
          echo "SRC_URL=${{ secrets.UAT_OIC_URL }}" >> $GITHUB_ENV
          echo "TGT_URL=${{ secrets.SIT_OIC_URL }}" >> $GITHUB_ENV

          echo "DOMAIN=${{ secrets.OCI_DOMAIN_URL }}" >> $GITHUB_ENV
          echo "CLIENT_ID=${{ secrets.CLIENT_ID }}" >> $GITHUB_ENV
          echo "CLIENT_SECRET=${{ secrets.CLIENT_SECRET }}" >> $GITHUB_ENV
          echo "SCOPE=${{ secrets.OIC_SCOPE }}" >> $GITHUB_ENV

      # ЁЯФР STEP 1: Get OAuth Token
      - name: Get Token
        run: |
          echo "ЁЯФР Generating token..."

          RESPONSE=$(curl -s -X POST "$DOMAIN/oauth2/v1/token" \
            -u "$CLIENT_ID:$CLIENT_SECRET" \
            -H "Content-Type: application/x-www-form-urlencoded" \
            -d "grant_type=client_credentials&scope=$SCOPE")

          echo "$RESPONSE"

          TOKEN=$(echo "$RESPONSE" | jq -r '.access_token')

          if [ "$TOKEN" = "null" ]; then
            echo "тЭМ Token generation failed"
            exit 1
          fi

          echo "TOKEN=$TOKEN" >> $GITHUB_ENV
          echo "тЬЕ Token ready"

      # ЁЯФН STEP 2: Validate Connections
      - name: Validate Source & Target
        run: |
          for ENV in SRC TGT; do
            URL_VAR="${ENV}_URL"
            URL=${!URL_VAR}

            echo "ЁЯФН Checking $ENV тЖТ $URL"

            STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
              -H "Authorization: Bearer $TOKEN" \
              "$URL/ic/api/integration/v1/integrations?limit=1")

            echo "$ENV STATUS: $STATUS"

            if [ "$STATUS" != "200" ]; then
              echo "тЭМ $ENV connection failed"
            else
              echo "тЬЕ $ENV connection OK"
            fi
          done

      # ЁЯУе STEP 3: Fetch Integrations
      - name: Fetch Integrations
        run: |
          echo "ЁЯУе Fetching integrations..."

          curl -s \
          -H "Authorization: Bearer $TOKEN" \
          "$SRC_URL/ic/api/integration/v1/integrations?limit=1000" \
          -o integrations.json

          COUNT=$(jq '.items | length // 0' integrations.json)
          echo "Total integrations: $COUNT"

      # ЁЯУж STEP 4: Export Integrations
      - name: Export Integrations
        run: |
          mkdir -p exports

          COUNT=$(jq '.items | length // 0' integrations.json)

          for i in $(seq 0 $(($COUNT - 1))); do
            NAME=$(jq -r ".items[$i].code" integrations.json)
            VERSION=$(jq -r ".items[$i].version" integrations.json)

            ID="$NAME|$VERSION"
            ENCODED=$(printf "%s%%7C%s" "$NAME" "$VERSION")
            FILE="exports/$NAME-$VERSION.iar"

            echo "ЁЯУж Exporting $ID"

            STATUS=$(curl -s -o "$FILE" -w "%{http_code}" \
              -H "Authorization: Bearer $TOKEN" \
              "$SRC_URL/ic/api/integration/v1/integrations/archive?integrationId=$ENCODED")

            if [ "$STATUS" != "200" ]; then
              echo "тЭМ Export failed: $ID"
              echo "$ID" >> failed_exports.txt
              continue
            fi

            echo "тЬЕ Exported: $ID"
          done

      # ЁЯУд Upload artifacts
      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: oic-exports
          path: exports/

      # ЁЯУе STEP 5: Import Integrations
      - name: Import Integrations
        run: |
          for FILE in exports/*.iar; do
            echo "ЁЯУе Importing $FILE"

            STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
              -H "Authorization: Bearer $TOKEN" \
              -X POST "$TGT_URL/ic/api/integration/v1/integrations/archive" \
              -F "file=@$FILE")

            if [ "$STATUS" != "200" ] && [ "$STATUS" != "204" ]; then
              echo "тЭМ Import failed: $FILE"
              echo "$FILE" >> failed_imports.txt
              continue
            fi

            echo "тЬЕ Imported: $FILE"
          done

      # тЪб STEP 6: Activate Integrations
      - name: Activate Integrations
        run: |
          for FILE in exports/*.iar; do
            BASE=$(basename "$FILE" .iar)

            NAME=$(echo "$BASE" | cut -d'-' -f1)
            VERSION=$(echo "$BASE" | cut -d'-' -f2)

            ENCODED=$(printf "%s%%7C%s" "$NAME" "$VERSION")

            echo "тЪб Activating $NAME|$VERSION"

            STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
              -H "Authorization: Bearer $TOKEN" \
              -X POST "$TGT_URL/ic/api/integration/v1/integrations/$ENCODED/activate")

            if [ "$STATUS" != "200" ] && [ "$STATUS" != "204" ]; then
              echo "тЭМ Activation failed: $NAME|$VERSION"
              echo "$NAME|$VERSION" >> failed_activation.txt
              continue
            fi

            echo "тЬЕ Activated: $NAME|$VERSION"
          done

      # ЁЯУК FINAL SUMMARY
      - name: Summary
        run: |
          echo "========== SUMMARY =========="

          echo "Failed Exports:"
          cat failed_exports.txt 2>/dev/null || echo "None"

          echo "Failed Imports:"
          cat failed_imports.txt 2>/dev/null || echo "None"

          echo "Failed Activations:"
          cat failed_activation.txt 2>/dev/null || echo "None"

          echo "============================="
